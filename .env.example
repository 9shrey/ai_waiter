# Copy this file to `.env` at the repo root (or to `backend/.env`) and fill in real values.
# docker-compose.yml reads this file automatically when placed at the repo root.

# --- Required ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional ---
# Set to "false" to disable TLS verification on outbound Gemini calls
# (useful behind a corporate MITM proxy). Defaults to "true" when unset.
GEMINI_VERIFY_SSL=false
